# Prisma (SQLite for MVP)
DATABASE_URL="file:./dev.db"

# AI Provider configurations (OpenAI / Gemini)
# Select which STT (Speech-to-Text) provider to use: 'openai' or 'gemini' 
STT_PROVIDER=openai

# Select which LLM provider to use for summary: 'openai' or 'gemini'
LLM_PROVIDER=gemini

# API Keys
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."

# The Base URL to properly build sharing links
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
